{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Android TV Remote",
  "version": "0.1.0",
  "identifier": "bd.anwar.androidtvremote",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun run dev:web",
    "beforeBuildCommand": "bun run build:web && bun run prepare:backend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Android TV Remote",
        "width": 400,
        "height": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "visible": false,
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "Android TV Remote Control",
    "longDescription": "A desktop application for controlling Android TVs through a web interface.",
    "category": "Utilities",
    "resources": [
      "../backend/src/**/*",
      "../backend/lib/**/*",
      "../backend/package.json",
      "../backend/package-lock.json",
      "../backend/node_modules/**/*",
      "sidecars/bin/androidtv"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "process": {
      "all": true,
      "sidecar": true
    }
  }
}
