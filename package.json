{
  "name": "android-tv-remote",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun run dev:web",
    "dev:web": "vite",
    "dev:desktop": "tauri dev",
    "build": "bun run build:web",
    "build:web": "tsc -b && vite build",
    "build:desktop": "tauri build",
    "lint": "biome check .",
    "format": "biome format --write .",
    "preview": "vite preview",
    "backend": "node backend/src/server.js",
    "dev:backend": "node backend/src/server.js",
    "prepare:backend": "cd backend && npm install --production && cd ../src-tauri/sidecars/bin && [ -f androidtv ] || cp $(which node) androidtv"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.1"
  }
}
